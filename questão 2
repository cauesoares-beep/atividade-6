@Override
public void atualizarHorariosDeMedicamento(String codigoMed,
        List<Horario> novosHorarios)
        throws MedicamentoNaoExisteException {

    Medicamento med = this.medicamentos.get(codigoMed);

    if (med == null) {
        throw new MedicamentoNaoExisteException(
                "Não existe medicamento com o código " + codigoMed);
    }

    med.setHorarios(novosHorarios);
}