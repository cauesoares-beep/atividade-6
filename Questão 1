@Override
public List<Medicamento> pesquisarMedicamentosDoHorario(Horario horario) {
    List<Medicamento> listaHorario = new ArrayList<>();

    for (Medicamento m : this.medicamentos.values()) {
        if (m.ehDoHorario(horario)) {
            listaHorario.add(m);
        }
    }

    return listaHorario;
}